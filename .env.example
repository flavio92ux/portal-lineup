# ===========================
# DATABASE CONFIGURATION
# ===========================
# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
POSTGRES_URL=postgresql://username:password@localhost:5432/portal_payload

# ===========================
# PAYLOAD CMS CONFIGURATION
# ===========================
# Secret key used to encrypt JWT authentication tokens
# Generate a secure random string: openssl rand -hex 12
PAYLOAD_SECRET=your_secret_key_here

# ===========================
# APPLICATION CONFIGURATION
# ===========================
# Public server URL for CORS, link generation, and API endpoints
# No trailing slash. Update to your production domain in production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ===========================
# SECURITY
# ===========================
# Secret key used to authenticate and validate cron job requests
# Keep this secret and update in production
CRON_SECRET=your_cron_secret_here

# Secret used to validate revalidate and preview requests from external services
# Generate a secure random string: openssl rand -hex 32
PREVIEW_SECRET=your_preview_secret_here

# ===========================
# CLOUDFLARE R2 CONFIGURATION
# ===========================
# Cloudflare R2 API endpoint
# Find your account ID in Cloudflare dashboard
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Cloudflare R2 API credentials
# Generate in R2 account settings under API tokens
R2_ACCESS_KEY_ID=your_access_key_id

# Cloudflare R2 secret access key
# Generated with the access key ID - keep this secret
R2_SECRET_ACCESS_KEY=your_secret_access_key

# R2 bucket name where media files will be stored
R2_BUCKET_NAME=your_bucket_name

# Public URL for accessing files from R2
# Use custom domain (e.g., https://cdn.yourdomain.com) or R2 dev URL
# Format: https://pub-xxxxx.r2.dev or https://cdn.yourdomain.com
R2_PUBLIC_URL=https://cdn.yourdomain.com

REVALIDATE_SECRET=YOUR_SECRET
